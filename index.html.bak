tation!", "footer": "📍 Cielo Vista Mall, El Paso TX | 📞 (915) 209-2060", "img": "day15_engagement.jpg", "type": "Engagement", "client": true}], "ads": [{"title": "Personalized Facial + Skin Consultation", "hook": "Not sure what your skin really needs?", "copy": "Begin with a thoughtful skin analysis, customized facial care, and a plan designed around your goals.", "cta": "📲 Message us 'GLOW' for a complimentary consultation!", "img": "ad_dermaplaning_facial.jpg", "adSet": "Local Skin Consultation"}, {"title": "Dermaplaning + Complete Facial", "hook": "Smoother, brighter-looking skin starts here.", "copy": "A complete treatment to deeply cleanse, refresh, and reveal a polished-looking complexion.", "cta": "📲 Message us 'GLOW' for a complimentary consultation!", "img": "ad_dermaplaning_facial.jpg", "adSet": "Facial Services"}, {"title": "BOTOX® Cosmetic", "hook": "Look refreshed. Feel confident.", "copy": "Explore a personalized BOTOX® Cosmetic plan for natural-looking results.", "cta": "📲 Message us 'GLOW' for a complimentary consultation!", "img": "ad_botox_results.jpg", "adSet": "BOTOX Cosmetic"}, {"title": "JUVÉDERM® Lip Fillers", "hook": "Natural definition, beautifully balanced.", "copy": "Personalized JUVÉDERM® lip filler treatments designed to complement your features.", "cta": "📲 Message us 'GLOW' for a complimentary consultation!", "img": "ad_botox_party_weekend.jpg", "adSet": "Lip Enhancement"}, {"title": "Microneedling", "hook": "Help your skin renew from within.", "copy": "A customized microneedling plan for smoother, brighter, refreshed-looking skin.", "cta": "📲 Message us 'GLOW' for a complimentary consultation!", "img": "ad_microneedling_tiers.jpg", "adSet": "Skin Renewal"}, {"title": "PRP Hair Restoration", "hook": "Start the conversation about healthier-looking hair.", "copy": "Explore PRP Hair Restoration for support with the appearance of density and healthier-looking hair.", "cta": "📲 Message us 'GLOW' for a complimentary consultation!", "img": "ad_neurotoxin_menu.jpg", "adSet": "Hair Restoration"}]};let state=JSON.parse(localStorage.getItem('ssl_state_jul2026')||'{"status":{},"notes":{}}');function save(){localStorage.setItem('ssl_state_jul2026',JSON.stringify(state))}function esc(s){return String(s).replace(/[&<>"']/g,x=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[x]))}function collect(){document.querySelectorAll('textarea').forEach(e=>state.notes[e.dataset.day]=e.value);save()}function render(){let f=window.currentFilter||'all';let list=DATA.posts.filter(p=>f==='all'||(state.status[p.day]||'pending')===f);document.querySelector('#posts').innerHTML=list.map(p=>{let s=state.status[p.day]||'pending';return `<article class="card ${s}" id="card-${p.day}"><div class="meta"><span>DAY ${p.day} • ${p.date} • 9:00 AM MT</span><span class="badge">${p.type}</span></div><img loading="lazy" src="images/${p.img}?v=7" alt="${esc(p.title)}" onerror="this.outerHTML='<div style='aspect-ratio:1;display:grid;place-items:center;color:#c9a84c'>📷 Image not available</div>'"><div class="body"><h3>${esc(p.title)}</h3><p class="hook">${esc(p.hook)}</p><p class="copy">${esc(p.copy)}</p><p class="cta">${esc(p.cta)}<br>${esc(p.footer)}</p><textarea data-day="${p.day}" placeholder="Notes for Jeny & Rick" onchange="collect()" onblur="collect()">${esc(state.notes[p.day]||'')}</textarea></div><div class="card-actions"><button class="approve" onclick="setStatus(${p.day},'approved')">✓ Approve</button><button class="skip" onclick="setStatus(${p.day},'skipped')">Skip</button><button onclick="edit(${p.day})">Edit copy</button></div></article>`}).join('');document.querySelector('#ads').innerHTML=DATA.ads.map(a=>`<article class="card ad"><img loading="lazy" src="images/${a.img}?v=7" alt="${esc(a.title)}" onerror="this.outerHTML='<div style='aspect-ratio:1;display:grid;place-items:center;color:#c9a84c'>📷 Image not available</div>'"><div class="body"><span class="badge">${esc(a.adSet)}</span><h3>${esc(a.title)}</h3><p class="hook">${esc(a.hook)}</p><p class="copy">${esc(a.copy)}</p><p class="cta">${esc(a.cta)}<br>${esc(DATA.posts[0].footer)}</p></div></article>`).join('');let counts=['approved','skipped','pending'].map(k=>[k,DATA.posts.filter(p=>(state.status[p.day]||'pending')===k).length]);document.querySelector('#stats').innerHTML=counts.map(x=>`<span class="chip">${x[0]}: ${x[1]}</span>`).join('')+`<span class="chip">Ads: ${DATA.ads.length}</span>`;document.querySelector('#bar').style.width=(counts[0][1]/30*100)+'%'}function setStatus(d,s){collect();state.status[d]=s;save();render()}function edit(d){let p=DATA.posts.find(x=>x.day===d);let val=prompt('Edit post copy (price-free):',p.copy);if(val!==null){p.copy=val;render()}}function filter(f,b){window.currentFilter=f;document.querySelectorAll('.filters button').forEach(x=>x.classList.remove('active'));b.classList.add('active');render()}function exportJSON(){collect();let blob=new Blob([JSON.stringify({calendar:DATA.posts,status:state.status,notes:state.notes},null,2)],{type:'application/json'});let a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='solace-jul-23-aug-21-2026-review.json';a.click()}function shareWhatsApp(){collect();let a=Object.values(state.status).filter(x=>x==='approved').length,s=Object.values(state.status).filter(x=>x==='skipped').length;let msg=`Solace Skin Lab review — July 23–August 21, 2026%0AApproved: ${a}%0ASkipped: ${s}%0APending: ${30-a-s}%0A${location.href}`;window.open('https://wa.me/526564535107?text='+msg)}function clearAll(){if(confirm('Clear all local approvals and notes?')){state={status:{},notes:{}};save();render()}}render();setTimeout(()=>document.querySelector('#loader').classList.add('hidden'),450);</script></body></html>