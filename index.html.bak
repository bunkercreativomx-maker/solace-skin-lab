<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Solace Skin Lab Med Spa | July–August 2026 Content Review</title><link rel="preconnect" href="https://fonts.googleapis.com"><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet"><style>
:root{--bg:#0d0d0d;--panel:#1a1a1a;--gold:#c9a84c;--cream:#f3ead7;--dim:#b9b3a8;--green:#62d990;--orange:#f5ae59}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--cream);font-family:Inter,Arial,sans-serif}.loader{position:fixed;inset:0;background:var(--bg);z-index:5;display:grid;place-items:center;color:var(--gold);letter-spacing:2px;transition:.4s}.loader.hidden{opacity:0;visibility:hidden}header{position:sticky;top:0;z-index:3;padding:18px 5%;background:#0d0d0dee;border-bottom:1px solid #c9a84c44;backdrop-filter:blur(12px)}h1,h2,h3{font-family:'Playfair Display',serif}h1{color:var(--gold);font-size:clamp(23px,4vw,34px);margin:0}header p{color:var(--dim);margin:5px 0 0;font-size:13px}main{max-width:1400px;margin:auto;padding:25px}.progress{height:6px;background:#333;border-radius:5px;margin:16px 0}.progress b{display:block;height:100%;width:0;background:var(--gold);border-radius:5px;transition:.4s}.stats,.filters,.actions{display:flex;gap:9px;flex-wrap:wrap;margin:14px 0}.chip,button{padding:8px 12px;border:1px solid #c9a84c55;border-radius:20px;background:#1a1a1a;color:var(--cream);font:600 12px Inter;cursor:pointer}button:hover,.active{border-color:var(--gold);color:var(--gold)}.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(295px,1fr));gap:18px}.card{background:var(--panel);border:1px solid #ffffff13;border-radius:14px;overflow:hidden;transition:.25s}.card:hover{transform:translateY(-4px);border-color:#c9a84c77;box-shadow:0 12px 35px #0008}.card.approved{border-color:#62d99088}.card.skipped{opacity:.55;border-color:#f5ae5988}img{display:block;width:100%;aspect-ratio:1;object-fit:cover;background:#222}.meta,.body,.card-actions{padding:13px 15px}.meta{display:flex;justify-content:space-between;color:var(--gold);font-size:12px;border-bottom:1px solid #ffffff12}.badge{color:#0d0d0d;background:var(--gold);padding:3px 7px;border-radius:10px;font-weight:700}h3{margin:0 0 8px;color:var(--gold);font-size:19px}.hook{font-weight:700;margin:0 0 8px}.copy{color:var(--dim);font-size:13px;line-height:1.55;white-space:pre-line;max-height:200px;overflow-y:auto}.cta{color:var(--gold);font-size:12px;font-weight:700;margin-top:11px;white-space:pre-line}textarea{width:100%;resize:vertical;min-height:45px;background:#111;color:var(--cream);border:1px solid #ffffff22;border-radius:7px;padding:8px;margin-top:10px}.card-actions{display:flex;gap:7px}.approve{color:var(--green)}.skip{color:var(--orange)}section{margin-top:42px}.ad{border-left:4px solid var(--gold)}.notice{background:#201e19;border-left:3px solid var(--gold);padding:16px;border-radius:8px;color:var(--dim);font-size:13px}@media(max-width:600px){main{padding:16px}}
</style></head><body><div class="loader" id="loader">SOLACE SKIN LAB MED SPA</div><header><h1>Solace Skin Lab Med Spa</h1><p>30-day content review • July 23 – August 21, 2026 • Cielo Vista Mall, El Paso TX</p></header><main><div class="progress"><b id="bar"></b></div><div class="stats" id="stats"></div><div class="filters"><button class="active" onclick="filter('all',this)">All</button><button onclick="filter('pending',this)">Pending</button><button onclick="filter('approved',this)">Approved</button><button onclick="filter('skipped',this)">Skipped</button></div><div class="actions"><button onclick="exportJSON()">Export JSON</button><button onclick="shareWhatsApp()">Share approval summary via WhatsApp</button><button onclick="clearAll()">Clear local status</button></div><section><h2>30-Day Content Calendar</h2><div class="grid" id="posts"></div></section><section><h2>Facebook Ad Concepts</h2><div class="grid" id="ads"></div></section><section class="notice"><strong>Client review:</strong> All new post copy is in English, uses the GLOW CTA, and omits prices from copy. Creative uses the current branded image set. Images are lazy loaded with an unavailable-image fallback.</section></main><script>const DATA={"startDate": "2026-07-23", "posts": [{"day": 1, "date": "Thu, Jul 23", "scheduledAt": "2026-07-23T15:00:00Z", "title": "Personalized Facial + Skin Consultation", "hook": "Not sure what your skin really needs?", "copy": "Our personalized consultation begins with a thoughtful skin analysis, a tailored facial treatment, and a plan built around your unique goals.", "cta": "📲 Message us 'GLOW' for a complimentary consultation!", "footer": "📍 Cielo Vista Mall, El Paso TX | 📞 (915) 209-2060", "img": "day02_facial_consultation.jpg", "type": "Service", "client": true}, {"day": 2, "date": "Fri, Jul 24", "scheduledAt": "2026-07-24T15:00:00Z", "title": "BOTOX® Cosmetic", "hook": "Look refreshed. Feel confident.", "copy": "BOTOX® Cosmetic can soften the appearance of fine lines w